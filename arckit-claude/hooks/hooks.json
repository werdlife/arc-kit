{
  "description": "ArcKit hooks: session init, version check, session learner (Stop + StopFailure), project context injection, filename enforcement, MCP tool auto-allow, security protection (file protection, secret detection, secret file scanning), provenance stamping on artefact writes (PostToolUse Write|Edit), and telemetry recording (PostToolUse for hook duration_ms + govreposcrape MCP calls; TaskCreated for agent spawns)",
  "hooks": {
    "Stop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/session-learner.mjs",
            "timeout": 10
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/session-learner.mjs",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/arckit-session.mjs",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/version-check.mjs",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/arckit-context.mjs",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/secret-detection.mjs",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "/arckit:pages",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/sync-guides.mjs",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "/arckit:health",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/graph-inject.mjs",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "/arckit:traceability",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/graph-inject.mjs",
            "timeout": 20
          }
        ]
      },
      {
        "matcher": "/arckit:analyze",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/graph-inject.mjs",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "/arckit:search",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/graph-inject.mjs",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "/arckit:impact",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/graph-inject.mjs",
            "timeout": 20
          }
        ]
      },
      {
        "matcher": "/arckit:navigator",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/graph-inject.mjs",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "/arckit:graph-report",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/graph-inject.mjs",
            "timeout": 20
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Read|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/allow-plugin-internals.mjs",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/inject-agent-context.mjs",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "if": "Write(/projects/**)",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/validate-arc-filename.mjs",
            "timeout": 5
          },
          {
            "type": "command",
            "if": "Write(/projects/**/vendors/scores.json)",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/score-validator.mjs",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/file-protection.mjs",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/secret-file-scanner.mjs",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "if": "Write(/projects/**)",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/update-manifest.mjs",
            "timeout": 5
          },
          {
            "type": "command",
            "if": "Write(/projects/**)",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/provenance-stamp.mjs",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "if": "Edit(/projects/**)",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/provenance-stamp.mjs",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/telemetry.mjs",
            "timeout": 3
          }
        ]
      }
    ],
    "TaskCreated": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/telemetry.mjs",
            "timeout": 3
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/allow-mcp-tools.mjs",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
