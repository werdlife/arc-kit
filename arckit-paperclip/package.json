{
  "name": "@tractorjuice/arckit-paperclip",
  "version": "4.12.2",
  "description": "ArcKit Enterprise Architecture Governance plugin for Paperclip — 68 commands for generating architecture artifacts",
  "type": "module",
  "main": "dist/worker.js",
  "types": "dist/worker.d.ts",
  "paperclipPlugin": {
    "manifest": "./dist/manifest.js",
    "worker": "./dist/worker.js"
  },
  "scripts": {
    "build": "tsc && mkdir -p dist/data && cp src/data/commands.json dist/data/commands.json",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@paperclipai/plugin-sdk": "^2026.416.0"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "typescript": "^5.7.3"
  },
  "files": [
    "dist/",
    "templates/",
    "references/"
  ],
  "author": "tractorjuice",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tractorjuice/arckit-paperclip.git"
  }
}
